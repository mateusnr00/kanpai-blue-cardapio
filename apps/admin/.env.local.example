NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# URL do site público (sem barra final). Ex: http://localhost:3000
# Usado pelo admin para disparar revalidação após mutações.
SITE_URL=http://localhost:3000

# Secret compartilhado com o site (apps/site/.env.local).
# Gere com: openssl rand -hex 32
REVALIDATE_SECRET=<mesmo-token-do-site>

# PostHog (opcional, usado na aba /comportamento).

# --- LINKS EXTERNOS ---
# Project Token: aparece na URL do projeto, ex: us.posthog.com/project/<TOKEN>
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=<sTMFPsFhdP1Ssg>
# Base do PostHog. Default https://us.posthog.com. Use eu.posthog.com se UE.
NEXT_PUBLIC_POSTHOG_APP_URL=https://us.posthog.com

# --- MÉTRICAS SERVER-SIDE ---
# IMPORTANTE: as proximas tres NAO podem ter NEXT_PUBLIC_ no nome. Sao
# secret reais — ficam apenas no servidor da Vercel, nunca no browser.
#
# 1) Personal API Key (comeca com phx_). Crie em:
#    posthog.com/settings/user-api-keys
#    Scopes minimos: Read em "query" e "insight".
POSTHOG_API_KEY=<phx_...>
# 2) Project ID numerico (ex: 442129). Aparece em Settings > Project
POSTHOG_PROJECT_ID=<442129>
# 3) Host da API. Default https://us.posthog.com
POSTHOG_API_HOST=https://us.posthog.com
