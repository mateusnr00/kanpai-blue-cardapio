NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Secret usado pelo endpoint /api/revalidate.
# Precisa ser o MESMO valor de apps/admin/.env.local (REVALIDATE_SECRET).
# Gere com: openssl rand -hex 32
REVALIDATE_SECRET=<gere-um-token-aleatorio>

# PostHog (opcional). Sem a key, o PostHogProvider é no-op.
# Pegue em https://us.posthog.com/project/settings -> Project API Key
NEXT_PUBLIC_POSTHOG_KEY=<phc_...>
# Default us.i.posthog.com. Use eu.i.posthog.com se criou projeto na UE.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Ligar banner LGPD (Aceitar/Recusar antes de capturar). Default desligado.
# Quando ligar, ative tambem session recording no painel do PostHog.
# NEXT_PUBLIC_LGPD_BANNER=1
